{
  "name": "geo-social-ai-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~54.0.33",
    "expo-dev-client": "^55.0.22",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "expo-linear-gradient": "~15.0.8",
    "react-native-maps": "1.20.1"
  }
}
